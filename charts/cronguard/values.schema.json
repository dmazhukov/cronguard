{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "thresholdSpec": {
      "type": "object",
      "properties": {
        "for": {"type": "string"},
        "severity": {"type": "string", "enum": ["info", "warning", "critical"]}
      }
    }
  },
  "properties": {
    "image": {
      "type": "object",
      "properties": {
        "repository": {"type": "string", "minLength": 1},
        "pullPolicy": {"type": "string", "enum": ["Always", "IfNotPresent", "Never"]},
        "tag": {"type": "string"}
      },
      "required": ["repository", "pullPolicy"]
    },
    "imagePullSecrets": {"type": "array", "items": {"type": "object"}},
    "extraArgs": {"type": "array", "items": {"type": "string"}},
    "extraEnv": {"type": "array", "items": {"type": "object"}},
    "nameOverride": {"type": "string"},
    "fullnameOverride": {"type": "string"},
    "replicaCount": {"type": "integer", "minimum": 1, "maximum": 10},
    "namespace": {"type": "string"},
    "leaderElection": {
      "type": "object",
      "properties": {"enabled": {"type": "boolean"}}
    },
    "metrics": {
      "type": "object",
      "properties": {"port": {"type": "integer", "minimum": 1, "maximum": 65535}}
    },
    "healthProbe": {
      "type": "object",
      "properties": {"port": {"type": "integer", "minimum": 1, "maximum": 65535}}
    },
    "serviceMonitor": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "interval": {"type": "string"},
        "scrapeTimeout": {"type": "string"}
      }
    },
    "prometheusRule": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "namespace": {"type": "string"},
        "labels": {"type": "object"},
        "interval": {"type": "string"},
        "thresholds": {
          "type": "object",
          "properties": {
            "scheduleMissed": {"$ref": "#/$defs/thresholdSpec"},
            "consecutiveFailures": {"$ref": "#/$defs/thresholdSpec"},
            "durationExceeded": {"$ref": "#/$defs/thresholdSpec"},
            "notReady": {"$ref": "#/$defs/thresholdSpec"},
            "operatorDown": {"$ref": "#/$defs/thresholdSpec"},
            "missedRunsBurnFast": {
              "type": "object",
              "properties": {
                "fastRate": {"type": "number", "minimum": 0},
                "slowRate": {"type": "number", "minimum": 0},
                "for": {"type": "string"},
                "severity": {"type": "string", "enum": ["info", "warning", "critical"]}
              }
            },
            "missedRunsBurnSlow": {
              "type": "object",
              "properties": {
                "fastRate": {"type": "number", "minimum": 0},
                "slowRate": {"type": "number", "minimum": 0},
                "for": {"type": "string"},
                "severity": {"type": "string", "enum": ["info", "warning", "critical"]}
              }
            }
          }
        }
      }
    },
    "crds": {
      "type": "object",
      "properties": {"install": {"type": "boolean"}}
    },
    "podAnnotations": {"type": "object"},
    "podLabels": {"type": "object"},
    "podSecurityContext": {"type": "object"},
    "securityContext": {"type": "object"},
    "resources": {"type": "object"},
    "nodeSelector": {"type": "object"},
    "tolerations": {"type": "array"},
    "affinity": {"type": "object"},
    "topologySpreadConstraints": {"type": "array", "items": {"type": "object"}},
    "podDisruptionBudget": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "minAvailable": {"oneOf": [{"type": "integer"}, {"type": "string"}]},
        "maxUnavailable": {"oneOf": [{"type": "integer"}, {"type": "string"}]}
      }
    },
    "priorityClassName": {"type": "string"},
    "terminationGracePeriodSeconds": {"type": "integer", "minimum": 1},
    "serviceAccount": {"type": "object"}
  }
}
