          "uid": "${DS_PROMETHEUS}"
        },
        "definition": "label_values(cronguard_condition{namespace=~\"$namespace\"}, cronjob)",
        "query": {
          "query": "label_values(cronguard_condition{namespace=~\"$namespace\"}, cronjob)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "hide": 0,
        "includeAll": true,
